{
  "name": "axis",
  "productName": "Axis",
  "version": "0.2.6",
  "description": "A minimalistic, customizable, and beautiful browser built on Electron",
  "main": "src/main.js",
  "scripts": {
    "postinstall": "node scripts/patch-electron-mac-display-name.js",
    "start": "node scripts/run-electron.js",
    "dev": "node scripts/run-electron.js --dev",
    "build": "npx electron-builder",
    "dist": "npx electron-builder --publish=never"
  },
  "overrides": {
    "tar": "^7.5.10",
    "ajv": "^8.18.0",
    "minimatch": "^10.2.3",
    "picomatch": "4.0.4",
    "@xmldom/xmldom": "0.8.12"
  },
  "keywords": [
    "browser",
    "electron",
    "minimalistic",
    "customizable"
  ],
  "author": "Axis Browser Team",
  "license": "SEE LICENSE IN LICENSE.md",
  "devDependencies": {
    "electron": "39.8.5",
    "electron-builder": "^26.4.0",
    "lodash": "^4.18.1",
    "minimatch": "^10.2.3",
    "picomatch": "4.0.4",
    "tar": "^7.5.10"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "jimp": "^0.22.12",
    "qrcode": "^1.5.4"
  },
  "build": {
    "appId": "com.axis.browser",
    "productName": "Axis",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "Axis_logo.png",
      "node_modules/**/*"
    ],
    "icon": "Axis_logo.png",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "Axis_logo.png"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}

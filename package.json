{
  "name": "axis",
  "productName": "Axis",
  "version": "0.3.0",
  "description": "A minimalistic, customizable, and beautiful browser built on Electron",
  "main": "src/main.js",
  "scripts": {
    "postinstall": "node scripts/patch-electron-mac-display-name.js",
    "start": "node scripts/run-electron.js",
    "dev": "node scripts/run-electron.js --dev",
    "build": "npx electron-builder",
    "dist": "npx electron-builder --publish=never"
  },
  "overrides": {
    "ip-address": "^10.2.0",
    "fast-uri": "^3.1.2",
    "tar": "^7.5.16",
    "ajv": "^8.18.0",
    "minimatch": "^10.2.3",
    "picomatch": "4.0.4",
    "@xmldom/xmldom": "0.8.13",
    "file-type": ">=21.3.1",
    "tmp": "0.2.7",
    "form-data": "^4.0.6",
    "js-yaml": "^4.3.0"
  },
  "keywords": [
    "browser",
    "electron",
    "minimalistic",
    "customizable"
  ],
  "author": "Axis Browser Team",
  "license": "SEE LICENSE IN LICENSE.md",
  "devDependencies": {
    "electron": "39.8.5",
    "electron-builder": "^26.4.0",
    "lodash": "^4.18.1",
    "minimatch": "^10.2.3",
    "picomatch": "4.0.4",
    "tar": "^7.5.16"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.14.1",
    "@primno/dpapi": "^2.0.1",
    "adm-zip": "^0.5.17",
    "dictionary-en": "^4.0.0",
    "electron-store": "^8.1.0",
    "jimp": "^1.6.1",
    "lz4js": "^0.2.0",
    "nspell": "^2.1.5",
    "qrcode": "^1.5.4"
  },
  "build": {
    "appId": "com.axis.browser",
    "productName": "Axis",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "Axis_logo.png",
      "node_modules/**/*"
    ],
    "icon": "Axis_logo.png",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "Axis_logo.png"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
